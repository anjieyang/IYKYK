# UncommonRoute environment variables
# Copy to .env and fill in your values:  cp .env.example .env

# Required for the comparison API (api.py) — Claude-as-judge
ANTHROPIC_API_KEY=

# Optional: upstream API for the proxy (default: https://openrouter.ai/api/v1)
# UNCOMMON_ROUTE_UPSTREAM=https://openrouter.ai/api/v1

# Optional: proxy port (default: 8403)
# UNCOMMON_ROUTE_PORT=8403
