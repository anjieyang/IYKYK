# UncommonRoute environment variables
# Copy to .env and fill in your values:  cp .env.example .env

# --- Upstream LLM API (required for proxy mode) ---
# Point to any OpenAI-compatible API and provide the corresponding key.

# Option 1: OpenAI direct
# UNCOMMON_ROUTE_UPSTREAM=https://api.openai.com/v1
# UNCOMMON_ROUTE_API_KEY=sk-...

# Option 2: OpenRouter (100+ models, single key)
# UNCOMMON_ROUTE_UPSTREAM=https://openrouter.ai/api/v1
# UNCOMMON_ROUTE_API_KEY=sk-or-...

# Option 3: Commonstack (multi-provider gateway)
# UNCOMMON_ROUTE_UPSTREAM=https://api.commonstack.ai/v1
# UNCOMMON_ROUTE_API_KEY=csk-...

# Option 4: Local (Ollama, vLLM, etc.) — no key needed
# UNCOMMON_ROUTE_UPSTREAM=http://127.0.0.1:11434/v1

# --- Proxy settings ---
# UNCOMMON_ROUTE_PORT=8403

# --- Legacy (still supported) ---
# COMMONSTACK_API_KEY=
